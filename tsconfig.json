{
    "compilerOptions": {
        "target": "ES2020",
        "module": "CommonJS",
        "jsx": "react",
        "jsxFactory": "jsx",
        "jsxFragmentFactory": "Fragment",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "outDir": "./.skrapa",
        "rootDir": "./",
        "resolveJsonModule": true
    },
    "include": ["src", "skrapa.d.ts"],
    "exclude": ["src/**/client.ts"]
}
